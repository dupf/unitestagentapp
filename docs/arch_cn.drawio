  <diagram id="closed-loop-flow" name="闭环引擎流程 Closed-Loop Flow">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- 标题 -->
        <mxCell id="f-title" value="&lt;b&gt;UnitestAgent 闭环引擎执行流程&lt;/b&gt;&lt;br&gt;Coverage-Driven Closed-Loop Execution Flow" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontColor=#1e293b;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="500" height="40" as="geometry" />
        </mxCell>
        <!-- Start -->
        <mxCell id="f-start" value="🚀 Start" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="80" width="100" height="40" as="geometry" />
        </mxCell>
        <!-- Phase 1: 初始化 -->
        <mxCell id="f-init" value="&lt;b&gt;Phase 1: 初始化&lt;/b&gt;&lt;br&gt;读取配置 / 检测语言&lt;br&gt;验证文件路径" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="570" y="150" width="160" height="60" as="geometry" />
        </mxCell>
        <!-- Phase 1.5: 初始覆盖率 -->
        <mxCell id="f-init-cov" value="&lt;b&gt;Phase 1.5: 初始覆盖率&lt;/b&gt;&lt;br&gt;解析现有覆盖率报告&lt;br&gt;注入提示词上下文" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="570" y="240" width="160" height="60" as="geometry" />
        </mxCell>
        <!-- 判断: 已达标? -->
        <mxCell id="f-check-init" value="覆盖率已达标?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="585" y="330" width="130" height="60" as="geometry" />
        </mxCell>
        <!-- Phase 2a: AI 生成 -->
        <mxCell id="f-generate" value="&lt;b&gt;Phase 2a: AI 测试生成&lt;/b&gt;&lt;br&gt;构建提示词 → 流式调用 LLM&lt;br&gt;解析 YAML 结构化输出" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="430" width="180" height="60" as="geometry" />
        </mxCell>
        <!-- Phase 2b: 写入文件 -->
        <mxCell id="f-write" value="&lt;b&gt;Phase 2b: 写入测试&lt;/b&gt;&lt;br&gt;追加测试代码到文件" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="570" y="520" width="160" height="50" as="geometry" />
        </mxCell>
        <!-- Phase 2c: 执行测试 -->
        <mxCell id="f-execute" value="&lt;b&gt;Phase 2c: 执行测试&lt;/b&gt;&lt;br&gt;运行 Shell 测试命令" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="570" y="600" width="160" height="50" as="geometry" />
        </mxCell>
        <!-- 判断: 测试通过? -->
        <mxCell id="f-check-pass" value="测试通过?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="590" y="680" width="120" height="60" as="geometry" />
        </mxCell>
        <!-- Phase 2d: 自修复 -->
        <mxCell id="f-repair" value="&lt;b&gt;Phase 2d: AI 自修复&lt;/b&gt;&lt;br&gt;分析错误 → 修复测试&lt;br&gt;记录失败信息" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="800" y="685" width="160" height="55" as="geometry" />
        </mxCell>
        <!-- Phase 2e: 覆盖率验证 -->
        <mxCell id="f-cov-verify" value="&lt;b&gt;Phase 2e: 覆盖率验证&lt;/b&gt;&lt;br&gt;解析新覆盖率报告&lt;br&gt;计算 Δ 变化量" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="570" y="775" width="160" height="55" as="geometry" />
        </mxCell>
        <!-- 判断: 覆盖率达标? -->
        <mxCell id="f-check-cov" value="覆盖率达标?&lt;br&gt;或已达最大迭代?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="295" y="690" width="150" height="70" as="geometry" />
        </mxCell>
        <!-- 反馈循环回到生成 -->
        <mxCell id="f-feedback" value="&lt;b&gt;Phase 2f: 反馈&lt;/b&gt;&lt;br&gt;覆盖率+失败信息→提示词" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="290" y="530" width="160" height="45" as="geometry" />
        </mxCell>
        <!-- Phase 3: 静态分析 -->
        <mxCell id="f-static" value="&lt;b&gt;Phase 3: 静态代码分析&lt;/b&gt;&lt;br&gt;规范 / 性能 / 安全" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="690" width="160" height="50" as="geometry" />
        </mxCell>
        <!-- Phase 4: 质量评分 -->
        <mxCell id="f-quality" value="&lt;b&gt;Phase 4: 质量评分&lt;/b&gt;&lt;br&gt;5 维度 + 变异测试分析" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="610" width="160" height="50" as="geometry" />
        </mxCell>
        <!-- Phase 5: 报告 -->
        <mxCell id="f-report" value="&lt;b&gt;Phase 5: 生成报告&lt;/b&gt;&lt;br&gt;HTML Dashboard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="530" width="160" height="50" as="geometry" />
        </mxCell>
        <!-- End -->
        <mxCell id="f-end" value="🏁 完成" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="130" y="470" width="100" height="40" as="geometry" />
        </mxCell>
        <!-- 连线 -->
        <mxCell id="e1" style="rounded=1;" edge="1" source="f-start" target="f-init" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="rounded=1;" edge="1" source="f-init" target="f-init-cov" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="rounded=1;" edge="1" source="f-init-cov" target="f-check-init" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="否" style="rounded=1;fontColor=#333;fontSize=10;" edge="1" source="f-check-init" target="f-generate" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4b" value="是" style="rounded=1;fontColor=#22c55e;fontSize=10;" edge="1" source="f-check-init" target="f-static" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="180" y="360" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e5" style="rounded=1;" edge="1" source="f-generate" target="f-write" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" style="rounded=1;" edge="1" source="f-write" target="f-execute" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" style="rounded=1;" edge="1" source="f-execute" target="f-check-pass" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" value="否" style="rounded=1;fontColor=#ef4444;fontSize=10;" edge="1" source="f-check-pass" target="f-repair" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9" value="是" style="rounded=1;fontColor=#22c55e;fontSize=10;" edge="1" source="f-check-pass" target="f-cov-verify" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9b" style="rounded=1;dashed=1;strokeColor=#b85450;" edge="1" source="f-repair" target="f-cov-verify" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="880" y="803" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e10" style="rounded=1;" edge="1" source="f-cov-verify" target="f-check-cov" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="370" y="803" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e11" value="否 (继续迭代)" style="rounded=1;fontColor=#9673a6;fontSize=10;strokeColor=#9673a6;strokeWidth=2;" edge="1" source="f-check-cov" target="f-feedback" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e11b" style="rounded=1;strokeColor=#9673a6;strokeWidth=2;dashed=1;" edge="1" source="f-feedback" target="f-generate" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="500" y="460" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e12" value="是 (退出循环)" style="rounded=1;fontColor=#22c55e;fontSize=10;" edge="1" source="f-check-cov" target="f-static" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e13" style="rounded=1;" edge="1" source="f-static" target="f-quality" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e14" style="rounded=1;" edge="1" source="f-quality" target="f-report" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e15" style="rounded=1;" edge="1" source="f-report" target="f-end" parent="1">
          <mxGeometry relative="1" as="geometry" />
