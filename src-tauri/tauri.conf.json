{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeBuildCommand": "pnpm build:fe",
    "beforeDevCommand": "pnpm dev:fe",
    "devPath": "http://localhost:1002",
    "distDir": "../dist"
  },
  "package": {
    "productName": "unitestagent",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": true,
      "os": {
        "all": true
      },
      "window": {
        "all": false,
        "close": true,
        "hide": true,
        "show": true,
        "startDragging": true
      },
      "http": {
        "all": true,
        "request": true,
        "scope": [
          "http://**",
          "https://**"
        ]

      },
      "shell": {
        "open": true
      },
      "fs": {
        "all": true,
        "scope": [
          "$DOWNLOAD/*"
        ]
      },
      "path": {
        "all": true
      },
      "dialog": {
        "all": true
      },
      "process": {
        "all": false,
        "relaunch": true,
        "exit": true
      }
    },
    "bundle": {
      "active": true,
      "category": "DeveloperTool",
      "copyright": "",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.ico"
      ],
      "deb": {
        "depends": []
      },
      "externalBin": [],
      "identifier": "unitestagent",
      "longDescription": "unitestagent Desktop Application",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      },
      "resources": [
      ],
      "shortDescription": "unitestagent",
      "targets": "all",
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      }
    },
    "security": {
      "csp": null
    },
    "updater": {
      "active": false,
      "dialog": false

    }
  }
}
